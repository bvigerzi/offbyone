---
import BaseLayout from './BaseLayout.astro';

interface Props {
  title: string;
  description?: string;
  pubDate: Date;
  updatedDate?: Date;
  tags?: string[];
}

const { title, description, pubDate, updatedDate, tags } = Astro.props;
---

<BaseLayout title={`${title} — unstructured`} description={description}>
  <header class="post-header">
    <a href="/" class="site-title">unstructured</a>
  </header>
  <main class="prose">
    <h1>{title}</h1>
    <time datetime={pubDate.toISOString()}>
      {pubDate.toLocaleDateString('en-US', {
        year: 'numeric',
        month: 'long',
        day: 'numeric',
      })}
    </time>
    {updatedDate && (
      <time class="updated" datetime={updatedDate.toISOString()}>
        Updated {updatedDate.toLocaleDateString('en-US', {
          year: 'numeric',
          month: 'long',
          day: 'numeric',
        })}
      </time>
    )}
    {tags && tags.length > 0 && (
      <div class="tags">
        {tags.map((tag) => (
          <span class="tag">{tag}</span>
        ))}
      </div>
    )}
    <article>
      <slot />
    </article>
  </main>
</BaseLayout>

<style>
  .post-header {
    padding: 1.5rem;
  }

  .site-title {
    font-family: var(--font-title);
    font-weight: 600;
    font-style: italic;
    font-size: 1.25rem;
    color: var(--color-text);
    text-decoration: none;
  }

  .site-title:hover {
    text-decoration: underline;
  }

  h1 {
    font-size: clamp(2rem, 1.5rem + 2.5vw, 3rem);
    margin-bottom: 0.25rem;
  }

  time {
    display: block;
    font-size: 0.875rem;
    color: var(--color-muted);
    margin-bottom: 0.25rem;
  }

  .updated {
    font-style: italic;
  }

  .tags {
    display: flex;
    gap: 0.5rem;
    margin-top: 0.5rem;
    margin-bottom: 2rem;
    flex-wrap: wrap;
  }

  .tag {
    font-size: 0.75rem;
    color: var(--color-muted);
    border: 1px solid var(--color-border);
    padding: 0.15rem 0.5rem;
    border-radius: 2px;
  }

  article {
    margin-top: 2rem;
  }
</style>
