<div class="shrinking-spacer" style="height: clamp(15vh, 20vw, 33vh);"></div>
<header
  id="shrinking-header"
  style="position: fixed; top: 0; left: 0; right: 0; z-index: 10; display: flex; align-items: center; justify-content: center; height: clamp(15vh, 20vw, 33vh); background-color: var(--color-bg); transition: background-color 0.2s; overflow: hidden;"
>
  <a
    id="shrinking-link"
    href="/"
    style="font-family: var(--font-title); font-weight: 600; font-style: italic; font-size: clamp(2.5rem, 10vw, 8rem); color: var(--color-text); text-decoration: none; white-space: nowrap; transition: color 0.2s;"
  >
    unstructured
  </a>
</header>

<script>
  const header = document.getElementById('shrinking-header');
  const link = document.getElementById('shrinking-link');
  let rafId = 0;

  const startH = header ? header.getBoundingClientRect().height : window.innerHeight * 0.33;
  const minH = window.innerHeight * 0.08;

  function handleScroll() {
    cancelAnimationFrame(rafId);
    rafId = requestAnimationFrame(() => {
      const scrollY = window.scrollY;
      const threshold = window.innerHeight * 0.25;
      const p = Math.min(scrollY / threshold, 1);
      if (header) header.style.height = `${startH - p * (startH - minH)}px`;
      if (link) link.style.fontSize = `clamp(2rem, ${8 - p * 6}rem, min(${8 - p * 6}rem, 10vw))`;
    });
  }

  window.addEventListener('scroll', handleScroll, { passive: true });
  handleScroll();
</script>
